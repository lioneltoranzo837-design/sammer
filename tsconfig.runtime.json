{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    "allowJs": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": []
  },
  "include": [
    "ts-src/main.ts",
    "ts-src/rendering/**/*.ts",
    "ts-src/types/runtime-*.d.ts"
  ]
}
