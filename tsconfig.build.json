{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "rootDir": "ts-src",
    "outDir": "src",
    "declaration": false,
    "sourceMap": false,
    "types": []
  },
  "include": [
    "ts-src/**/*.ts",
    "ts-src/**/*.d.ts"
  ]
}
